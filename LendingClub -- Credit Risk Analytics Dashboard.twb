      <aliases enabled='yes' />
      <column caption='Approved' datatype='integer' name='[Calculation_0110978364919808]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [predicted_default_proba] &lt;= [Parameters].[Parameter 1] THEN 1 ELSE 0 END' />
      </column>
      <column caption='Approved Volume' datatype='real' name='[Calculation_0110978365042689]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [predicted_default_proba] &lt;= [Parameters].[Parameter 1] THEN [loan_amnt] ELSE 0 END)' />
      </column>
      <column caption='Approved Default Rate' datatype='real' name='[Calculation_0110978365132802]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [predicted_default_proba] &lt;= [Parameters].[Parameter 1] THEN [actual_default] ELSE 0 END) &#10;/ &#10;SUM(IF [predicted_default_proba] &lt;= [Parameters].[Parameter 1] THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Rejected Volume' datatype='real' name='[Calculation_0110978365276163]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [predicted_default_proba] &gt; [Parameters].[Parameter 1] THEN [loan_amnt] ELSE 0 END)' />
      </column>
      <column caption='Expected Loss Dynamic' datatype='real' name='[Calculation_0110978365333508]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [predicted_default_proba] &lt;= [Parameters].[Parameter 1] THEN [predicted_default_proba] * [loan_amnt] * [Parameters].[Parameter 2] ELSE 0 END)' />
      </column>
      <column caption='Interest Revenue Approved' datatype='real' name='[Calculation_0110978365407237]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [predicted_default_proba] &lt;= [Parameters].[Parameter 1] THEN [loan_amnt] * [int_rate] / 100 ELSE 0 END)' />
      </column>
      <column caption='Net Margin' datatype='real' name='[Calculation_0110978365464582]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0110978365407237] - [Calculation_0110978365333508]) / [Calculation_0110978365042689]' />
      </column>
      <column caption='Model AUC' datatype='real' name='[Calculation_0198595050348544]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ MAX(0.7329) }' />
      </column>
      <column caption='Risk Separation' datatype='integer' name='[Calculation_0198595051560961]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ MAX(16) }' />
      </column>
