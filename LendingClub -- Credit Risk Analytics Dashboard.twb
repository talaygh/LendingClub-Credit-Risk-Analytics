              <calculation class='tableau' formula='1.0' />
              <range granularity='0.01' max='1.0' min='0.0' />
            </column>
            <column caption='LGD' datatype='real' name='[Parameter 2]' param-domain-type='range' role='measure' type='quantitative' value='0.5'>
              <calculation class='tableau' formula='0.5' />
              <range granularity='0.01' max='0.95' min='0.5' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0w288c41qr28hs1aq2o371qkz1jn'>
            <column caption='Approved Volume' datatype='real' name='[Calculation_0110978365042689]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [predicted_default_proba] &lt;= [Parameters].[Parameter 1] THEN [loan_amnt] ELSE 0 END)' />
            </column>
            <column caption='Expected Loss Dynamic' datatype='real' name='[Calculation_0110978365333508]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [predicted_default_proba] &lt;= [Parameters].[Parameter 1] THEN [predicted_default_proba] * [loan_amnt] * [Parameters].[Parameter 2] ELSE 0 END)' />
