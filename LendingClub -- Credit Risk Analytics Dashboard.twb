              <zone forceUpdate='true' h='52333' id='3' type-v2='text' w='49429' x='571' y='889'>
                <formatted-text>
                  <run bold='true' fontcolor='#00d4ff' fontsize='18'>Methodology</run>
                  <run>Æ&#10;&#10;</run>
                  <run bold='true' fontsize='14'>Data: Lending Club 2007–2018, 500K stratified sample (from 2.26M)</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontsize='14'>Model: XGBoost, isotonic-calibrated, AUC 0.73</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontsize='14'>Features: 47 engineered (excludes 23 post-default leakage fields)</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontsize='14'>Validation: Stratified split, average precision + Brier score</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontsize='14'>Risk Decile: 16x separation (top vs bottom decile default rates)</run>
                  <run>Æ&#10;&#10;</run>
                  <run bold='true' fontcolor='#ff8c42' fontsize='18'>Limitations:</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontsize='14'>- Random split (production would use forward-time)</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontsize='14'>- LGD assumed at 0.75 (sensitivity analysis would refine)</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontsize='14'>- Time value of money not discounted</run>
                </formatted-text>
                <zone-style>
                  <format attr='border-color' value='#000000' />
                  <format attr='border-style' value='none' />
                  <format attr='border-width' value='0' />
                  <format attr='margin' value='4' />
